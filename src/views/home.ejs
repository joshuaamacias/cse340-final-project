<%- include('partials/header') %>

<section class="home-hero" style="background-image: linear-gradient(90deg, rgba(13, 34, 63, .87), rgba(13, 34, 63, .35)), url('https://www.churchofjesuschrist.org/imgs/0f1b6d1d7dee7237a98b7bf9feec68bbef7b3804/full/800,/0/default');">
    <div>
        <p class="eyebrow">TEMPLE PROGRESS TRACKER</p>
        <h1>Follow temple progress around the world.</h1>
        <p>Explore current temple updates and share respectful photos of construction progress with the community.</p>
        <a href="/directory">Explore temples</a>
    </div>
</section>

<section class="home-news">
    <p class="eyebrow">OFFICIAL NEWSROOM UPDATES</p>
    <h2>Latest Temple News</h2>
    <p>Recent temple announcements, open houses, and milestones from the Church Newsroom.</p>
    <div class="news-feed">
    <% news.forEach(item => { %>
        <article class="news-card">
            <h3><%= item.title %></h3>
            <small><%= item.date %></small>
            <p><%= item.summary %></p>
            <a href="<%= item.url %>" target="_blank" rel="noopener noreferrer">Read official update <span aria-hidden="true">→</span></a>
        </article>
    <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
