<%- include('partials/header') %>

<h2>Latest Temple Updates</h2>
<p>Welcome! Stay up to date with construction, dedications, and news regarding temples worldwide.</p>

<section class="news-feed">
    <% news.forEach(item => { %>
        <article class="news-card">
            <div class="card-image-container" style="width: 100%; height: 200px; overflow: hidden; border-radius: 4px; margin-bottom: 12px;">
                <img src="<%= item.image %>" alt="<%= item.title %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1548625361-155deee2627e?w=500';">
            </div>
            
            <h3><%= item.title %></h3>
            <small><%= item.date %></small>
            <p><%= item.snippet %></p>
        </article>
    <% }) %>
</section>

<%- include('partials/footer') %>