<%- include('../partials/header') %>

<div style="text-align: center; padding: 2rem 0; max-width: 600px; margin: 0 auto;">
    <h2>500 - Server Error</h2>
    <p style="margin-bottom: 1.5rem;">Oops! Something went wrong on our end. We are looking into it.</p>
    
    <% if (typeof error !== 'undefined') { %>
        <pre style="text-align: left; background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 5px; overflow-x: auto;"><%= error.message %></pre>
    <% } %>

    <br>
    <a href="/" style="display: inline-block; margin-top: 1.5rem; color: #2c3e50; font-weight: bold; text-decoration: none; background: #e2e8f0; padding: 0.5rem 1rem; border-radius: 5px;">
        🏠 Return Home
    </a>
</div>

<%- include('../partials/footer') %>