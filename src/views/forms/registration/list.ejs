<%- include('../../partials/header') %>
<main>    
    <h1><%= title %></h1>    
    
    <% if (users && users.length > 0) { %>
        <div class="users-list">            
            <% users.forEach(listUser => { %>
                <% 
                    // Calculate permissions for this user card
                    // 'user' variable contains the current logged-in user (from session)
                    // 'listUser' is the user from the users array we're currently rendering
                    const currentUser = typeof isLoggedIn !== 'undefined' && isLoggedIn ? user : null;
                    const canEdit = currentUser && (currentUser.id === listUser.id || currentUser.roleName === 'admin');
                    const canDelete = currentUser && currentUser.roleName === 'admin' && currentUser.id !== listUser.id;
                %>
                <div class="user-card">                    
                    <div class="user-header">                        
                        <h3><%= listUser.name %></h3>                        
                        <span class="user-id">ID: <%= listUser.id %></span>                    
                    </div>                    
                    <div class="user-details">                        
                        <div class="detail-item">                            
                            <div class="label">Email</div>                            
                            <div class="value"><%= listUser.email %></div>                        
                        </div>                        
                        <div class="detail-item">                            
                            <div class="label">Registered</div>                            
                            <div class="value">
                                <%= new Date(listUser.created_at).toLocaleDateString() %>
                            </div>                        
                        </div>                    
                        <div class="detail-item">
                            <div class="label">Role</div>
                            <div class="value"><%= listUser.roleName %></div>
                        </div>
                    </div>                

                    <% if (canEdit || canDelete) { %>
                        <div class="user-actions" style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #eee;">
                            <% if (canEdit) { %>
                                <a href="/register/<%= listUser.id %>/edit" class="btn btn-edit">Edit</a>
                            <% } %>
                            <% if (canDelete) { %>
                                <form method="POST" action="/register/<%= listUser.id %>/delete" style="display: inline; margin-left: 10px;">
                                    <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                                </form>
                            <% } %>
                            <% if (currentUser && currentUser.roleName === 'admin' && currentUser.id !== listUser.id) { %>
                                <form method="POST" action="/register/<%= listUser.id %>/role" style="display: inline; margin-left: 10px;">
                                    <label for="role-<%= listUser.id %>">Role</label>
                                    <select id="role-<%= listUser.id %>" name="roleName">
                                        <option value="user" <%= listUser.roleName === 'user' ? 'selected' : '' %>>Registered User</option>
                                        <option value="admin" <%= listUser.roleName === 'admin' ? 'selected' : '' %>>Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-edit">Save role</button>
                                </form>
                            <% } %>
                        </div>
                    <% } %>
                </div>            
            <% }); %>        
        </div>    
    <% } else { %>
        <p class="no-users">No users registered yet.</p>    
    <% } %>
</main>
<%- include('../../partials/footer') %>
