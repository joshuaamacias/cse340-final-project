<%- include('partials/header') %>
<div style="max-width: 800px; margin: 40px auto; padding: 0 20px; font-family: sans-serif;">
    
    <a href="/directory" class="back-link" style="text-decoration: none; color: #0056b3; display: inline-block; margin-bottom: 20px;">
        ← Back to Global Directory
    </a>

    <article class="temple-detail-container" style="background: #ffffff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        
        <div class="detail-image-container" style="width: 100%; max-height: 400px; overflow: hidden; border-radius: 6px; margin-bottom: 20px;">
            <img src="<%= item.image %>" alt="<%= item.title %>" style="width: 100%; height: auto; object-fit: cover;" onerror="this.src='/images/placeholder.jpg';">
        </div>

        <h1 style="font-size: 2.5rem; color: #111; margin-bottom: 10px;"><%= item.title %></h1>
        
        <div class="meta-info" style="margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
            <p style="margin: 5px 0;"><strong>Status:</strong> <span class="status-tag" style="background: #eef2f7; padding: 4px 8px; border-radius: 4px;"><%= item.rawStatus %></span></p>
            <% if (item.date) { %>
                <p style="margin: 5px 0; color: #555;"><strong>Date/Timeline:</strong> <%= item.date %></p>
            <% } %>
        </div>

        <div class="content-body" style="font-size: 1.1rem; line-height: 1.6; color: #333;">
            <p><%= item.snippet %></p>
        </div>
    </article>

    <section class="temple-gallery" aria-labelledby="gallery-title">
        <div class="gallery-heading">
            <div>
                <p class="eyebrow">COMMUNITY UPDATES</p>
                <h2 id="gallery-title">Photo Gallery</h2>
            </div>
            <% if (isLoggedIn) { %><a class="gallery-upload-link" href="/photos/upload">Share a photo</a><% } %>
        </div>

        <% if (photos.length > 0) { %>
            <div class="photo-grid">
                <% photos.forEach(photo => { %>
                    <figure class="photo-card">
                        <img src="<%= photo.file_path %>" alt="Community photo of <%= item.title %>" loading="lazy">
                        <figcaption>
                            <% if (photo.caption) { %><p><%= photo.caption %></p><% } %>
                            <small>Shared by <%= photo.contributor_name %> · <%= new Date(photo.created_at).toLocaleDateString() %></small>
                        </figcaption>
                    </figure>
                <% }) %>
            </div>
        <% } else { %>
            <div class="gallery-empty">
                <p>No community photos have been approved yet. <% if (isLoggedIn) { %>Be the first to share a recent update.<% } %></p>
            </div>
        <% } %>

        <% if (!isLoggedIn) { %>
            <p class="gallery-sign-in"><a href="/login">Sign in</a> to share a photo of this temple.</p>
        <% } %>
    </section>
    
</div>
<%- include('partials/footer') %>
