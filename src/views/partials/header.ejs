<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <%- renderStyles() %>
</head>
<body>
    <header class="site-header">
        <!-- Top thin decorative bar -->
        <div class="header-top-bar"></div>
        
        <div class="header-nav-container">
            
           <!-- Hanging Logo Block -->
        <a href="/" class="header-logo-block">
            <!-- Your logo image with text included -->
            <img src="/images/temple-logo-white.png" alt="Temple Icon" class="header-logo-img">
        </a>

            <!-- Right-aligned Navigation -->
            <nav class="header-main-nav">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/directory">Temples Directory</a></li>
                    <li><a href="/photos">New Photos</a></li>
                    
                    <!-- Library Dropdown -->
                    <li class="dropdown">
                        <a href="#" class="dropbtn">Library ▾</a>
                        <div class="dropdown-content">
                            <a href="/library/quotes">Quotes</a>
                            <a href="/library/facts">Interesting Facts</a>
                            <a href="/library/designs">Temple Designs</a>
                            <a href="/library/proposed">Proposed Temples</a>
                        </div>
                    </li>
                    
                    <li><a href="/contact">Contact</a></li>
                    <% if (isLoggedIn) { %>
                        <li><a href="/dashboard">Dashboard</a></li>
                        <% if (user && user.roleName === 'admin') { %>
                            <li><a href="/register/list">Manage Users</a></li>
                            <li><a href="/admin/photos">Review Photos</a></li>
                        <% } %>
                        <li><a href="/logout">Logout</a></li>
                    <% } else { %>
                        <li><a href="/login">Login</a></li>
                        <li><a href="/register">Register</a></li>
                    <% } %>
                </ul>
            </nav>
            
        </div>
    </header>
    <main>
